{
  "name": "hwp-crypto",
  "version": "0.1.1",
  "description": "Decrypt password-protected HWP/HWPX files and extract text",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "hwp-crypto": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/test/cipher.test.js dist/test/hwpx.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "hwp",
    "hwpx",
    "hancom",
    "decrypt",
    "password"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dumoknam/hwp-crypto.git"
  },
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "cfb": "^1.2.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
